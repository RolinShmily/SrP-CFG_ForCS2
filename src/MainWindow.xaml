<Window x:Class="SrPInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SrP-CFG 安装器" Height="680" Width="1000" MinHeight="680"
        SizeToContent="Height" MaxHeight="1200"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Image x:Name="AppIconImage" Width="32" Height="32" Margin="0,0,10,0" VerticalAlignment="Center"
                   Source="/Resources/app.ico" Stretch="Uniform"
                   Visibility="Visible"/>
            <TextBlock VerticalAlignment="Center">
                <Run Text="SrP-CFG 安装器 v2" FontSize="22" FontWeight="Bold"/>
                <Run Text=" | " FontSize="16" Foreground="#999"/>
                <Hyperlink NavigateUri="https://github.com/RolinShmily/SrP-CFG_ForCS2" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#0078D4" FontSize="14">
                    <Run Text="GitHub项目地址" TextDecorations="None"/>
                </Hyperlink>
                <Run Text="  " FontSize="14"/>
                <Hyperlink NavigateUri="https://blog.srprolin.top/posts/srp-cfg/#srp-cfg_forcs2" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#0078D4" FontSize="14">
                    <Run Text="作者的博客空间" TextDecorations="None"/>
                </Hyperlink>
                <Run Text="  " FontSize="14"/>
                <Hyperlink NavigateUri="https://doc.srprolin.top/SrP-CFG_CS2/srpcfg-2.html" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#0078D4" FontSize="14">
                    <Run Text="最新CFG文件下载" TextDecorations="None"/>
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <!-- Update Notification Banner -->
        <Border x:Name="UpdateBanner" Grid.Row="1"
                Background="#FFF3CD" BorderBrush="#FFEEBA" BorderThickness="1"
                CornerRadius="4" Padding="12,8" Margin="0,0,0,15"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13">
                    <Run Text="&#x26A0;"/>
                    <Run x:Name="UpdateMessage" Foreground="#856404"/>
                </TextBlock>
                <Button Grid.Column="1" x:Name="OpenReleaseButton"
                        Content="查看更新" FontSize="12" Padding="12,4" Margin="10,0,0,0"
                        Background="#0078D4" Foreground="White" BorderBrush="#005A9E"
                        Click="OpenReleaseButton_Click" Cursor="Hand"/>
                <Button Grid.Column="2" x:Name="DismissUpdateButton"
                        Content="&#x2715;" FontSize="12" Padding="8,4" Margin="5,0,0,0"
                        Background="Transparent" Foreground="#856404" BorderThickness="0"
                        Click="DismissUpdateButton_Click" Cursor="Hand"
                        ToolTip="忽略此版本更新"/>
            </Grid>
        </Border>

        <!-- Options -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <CheckBox x:Name="InstallCfgCheckBox" IsChecked="True" Content="安装 CFG 文件（全局配置）" />
            <Grid Margin="25,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="目标路径:" VerticalAlignment="Center" FontSize="12"/>
                <TextBox Grid.Column="1" Text="{Binding Cs2CfgPath, Mode=OneWay, TargetNullValue='请点击刷新路径检测或手动选择'}" IsReadOnly="True" TextWrapping="Wrap"
                         Height="30" VerticalContentAlignment="Center"/>
                <Button Grid.Column="2" x:Name="SelectCfgFolderButton" Content="..." Padding="10,3" Margin="5,0,0,0"
                        Click="SelectCfgFolderButton_Click" Width="40" Height="30"/>
            </Grid>
            <Grid Margin="25,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="备份位置:" VerticalAlignment="Center" FontSize="12"/>
                <TextBox Grid.Column="1" x:Name="CfgBackupTextBox" IsReadOnly="True" TextWrapping="Wrap"
                         Height="30" VerticalContentAlignment="Center" Text="{Binding CfgBackupPath, Mode=OneWay, TargetNullValue='安装前将自动备份'}"/>
                <Button Grid.Column="2" x:Name="OpenCfgBackupButton" Content="打开文件夹" Padding="8,3" Margin="5,0,0,0"
                        Click="OpenCfgBackupButton_Click" Height="30"/>
            </Grid>

            <CheckBox x:Name="InstallVideoCheckBox" IsChecked="False" Content="安装 视频预设文件（用户配置）" Margin="0,10,0,0"/>

            <!-- Steam ID 查找指南 -->
            <Expander x:Name="SteamGuideExpander" Margin="25,10,0,0" ExpandDirection="Down"
                      Expanded="SteamGuideExpander_Expanded" Collapsed="SteamGuideExpander_Collapsed">
                <Expander.Header>
                    <TextBlock Foreground="#0078D4" FontWeight="Bold" FontSize="12">
                        📖 如何查找我的 Steam 用户 (好友代码)？
                    </TextBlock>
                </Expander.Header>
                <StackPanel Margin="10,8,0,10">
                    <!-- 图片展示区域 -->
                    <Border BorderBrush="#CCCCCC"
                            BorderThickness="1"
                            CornerRadius="5"
                            Background="White"
                            Padding="5">
                        <Image x:Name="SteamGuideImage"
                               Source="/Resources/navi.png"
                               Stretch="Uniform"
                               MaxWidth="600"
                               MaxHeight="450"
                               HorizontalAlignment="Left"
                               MouseLeftButtonUp="SteamGuideImage_MouseUp"
                               Cursor="Hand"/>
                    </Border>

                    <!-- 提示文字 -->
                    <TextBlock Margin="0,10,0,0"
                               FontSize="11"
                               Foreground="#666666"
                               TextWrapping="Wrap">
                        <Run Text="💡 按照图中步骤操作，找到你的Steam好友ID后，"/>
                        <LineBreak/>
                        <Run Text="在上方的下拉框中选择对应的数字ID即可。如果userdata文件夹中只有一个账号，"/>
                        <LineBreak/>
                        <Run Text="系统通常会自动选中它。"/>
                    </TextBlock>
                </StackPanel>
            </Expander>

            <Grid Margin="25,0,0,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Steam 用户:" VerticalAlignment="Center" FontSize="12"/>
                <ComboBox x:Name="SteamUserComboBox" Grid.Row="0" Grid.Column="1" SelectionChanged="SteamUserComboBox_SelectionChanged"
                          Height="30"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="目标路径:" VerticalAlignment="Center" FontSize="12" Margin="0,5,0,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding VideoCfgPath, Mode=OneWay, TargetNullValue='请选择 Steam 用户'}" IsReadOnly="True"
                         TextWrapping="Wrap" Height="30" VerticalContentAlignment="Center" Margin="0,5,0,0"/>
                <Button Grid.Row="1" Grid.Column="2" x:Name="SelectVideoFolderButton" Content="..." Padding="10,3" Margin="5,5,0,0"
                        Click="SelectVideoFolderButton_Click" Width="40" Height="30"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="备份位置:" VerticalAlignment="Center" FontSize="12" Margin="0,5,0,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="VideoBackupTextBox" IsReadOnly="True" TextWrapping="Wrap"
                         Height="30" VerticalContentAlignment="Center" Margin="0,5,0,0" Text="{Binding VideoBackupPath, Mode=OneWay, TargetNullValue='安装前将自动备份'}"/>
                <Button Grid.Row="2" Grid.Column="2" x:Name="OpenVideoBackupButton" Content="打开文件夹" Padding="8,3" Margin="5,5,0,0"
                        Click="OpenVideoBackupButton_Click" Height="30"/>
            </Grid>

            <CheckBox x:Name="InstallAnnotationsCheckBox" IsChecked="False" Content="安装 地图指南预设文件" Margin="0,10,0,0"/>
            <Grid Margin="25,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="目标路径:" VerticalAlignment="Center" FontSize="12"/>
                <TextBox Grid.Column="1" x:Name="AnnotationsPathTextBox" Text="{Binding AnnotationsPath, Mode=OneWay, TargetNullValue='请点击刷新路径检测'}" IsReadOnly="True"
                         TextWrapping="Wrap" Height="30" VerticalContentAlignment="Center"/>
                <Button Grid.Column="2" x:Name="SelectAnnotationsFolderButton" Content="..." Padding="10,3" Margin="5,0,0,0"
                        Click="SelectAnnotationsFolderButton_Click" Width="40" Height="30"/>
            </Grid>
            <Grid Margin="25,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="备份位置:" VerticalAlignment="Center" FontSize="12"/>
                <TextBox Grid.Column="1" x:Name="AnnotationsBackupTextBox" IsReadOnly="True" TextWrapping="Wrap"
                         Height="30" VerticalContentAlignment="Center" Text="{Binding AnnotationsBackupPath, Mode=OneWay, TargetNullValue='安装前将自动备份'}"/>
                <Button Grid.Column="2" x:Name="OpenAnnotationsBackupButton" Content="打开文件夹" Padding="8,3" Margin="5,0,0,0"
                        Click="OpenAnnotationsBackupButton_Click" Height="30"/>
            </Grid>
        </StackPanel>

        <!-- Drag & Drop Area -->
        <GroupBox Grid.Row="3" Header="文件选择" Margin="0,0,0,15">
            <Grid Margin="10">
                <Border x:Name="DropZoneBorder" BorderBrush="#CCCCCC" BorderThickness="2"
                        Background="#FAFAFA" CornerRadius="5" Padding="20" Height="80"
                        AllowDrop="True" Drop="DropZone_Drop" DragOver="DropZone_DragOver"
                        DragLeave="DropZone_DragLeave"
                        MouseLeftButtonUp="DropZoneBorder_Click"
                        Cursor="Hand">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📁 点击选择或拖放 ZIP/CFG 文件到此" FontSize="14"
                                   HorizontalAlignment="Center" Foreground="#666666"/>
                        <TextBlock x:Name="SelectedFileTextBlock" Text="" FontSize="12"
                                   HorizontalAlignment="Center" Foreground="#0078D4" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </GroupBox>

        <!-- Log Output -->
        <GroupBox Grid.Row="4" Header="日志输出" Margin="0,15,0,0">
            <RichTextBox x:Name="LogTextBox" IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="11" Background="#FAFAFA" BorderThickness="0" Padding="5"
                     MinHeight="120" MaxHeight="300" Height="150"/>
        </GroupBox>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,15,0,0" HorizontalAlignment="Right" VerticalAlignment="Top">
            <Button x:Name="RefreshButton" Content="刷新路径" Click="RefreshButton_Click"
                    Margin="10,0,0,0" Background="#3b3b3b" Foreground="White" BorderBrush="#707070" Padding="20,5" Height="32" MinWidth="100" FontSize="14" VerticalAlignment="Center" VerticalContentAlignment="Center"/>
            <Button x:Name="BackupButton" Content="进行备份" Click="BackupButton_Click"
                    Margin="10,0,0,0" Background="#6B8E23" Foreground="White" BorderBrush="#556B2F" Padding="20,5" Height="32" MinWidth="100" FontSize="14" VerticalAlignment="Center" VerticalContentAlignment="Center"/>
            <Button x:Name="InstallButton" Content="开始安装" Click="InstallButton_Click"
                    Margin="10,0,0,0" Background="#0078D4" Foreground="White" BorderBrush="#005A9E" Padding="20,5" Height="32" MinWidth="100" FontSize="14" VerticalAlignment="Center" VerticalContentAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
