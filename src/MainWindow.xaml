<Window x:Class="SrPInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SrP-CFG 安装器"
        Width="1050" MinHeight="680"
        SizeToContent="Height" MaxHeight="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgPrimary}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== Row 0: Header Bar ========== -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgSurface}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Width="28" Height="28" Margin="0,0,10,0"
                           Source="/Resources/app.ico" Stretch="Uniform"
                           VerticalAlignment="Center"/>
                    <TextBlock VerticalAlignment="Center" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}">
                        <Run Text="SrP-CFG"/>
                        <Run Text="安装器" Foreground="{DynamicResource AccentBrush}"/>
                        <Run Text="v2" FontSize="13" Foreground="{DynamicResource TextSecondary}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Header link buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,16,0">
                        <Hyperlink NavigateUri="https://github.com/RolinShmily/SrP-CFG_ForCS2"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{DynamicResource LinkBrush}"
                                   FontSize="12" TextDecorations="None">
                            <Run Text="GitHub"/>
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center" Margin="0,0,16,0">
                        <Hyperlink NavigateUri="https://blog.srprolin.top/posts/srp-cfg/#srp-cfg_forcs2"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{DynamicResource LinkBrush}"
                                   FontSize="12" TextDecorations="None">
                            <Run Text="文档"/>
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center">
                        <Hyperlink NavigateUri="https://doc.srprolin.top/SrP-CFG_CS2/srpcfg-2.html"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{DynamicResource LinkBrush}"
                                   FontSize="12" TextDecorations="None">
                            <Run Text="下载"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== Row 1: Update Banner (collapsed by default) ========== -->
        <Border Grid.Row="1"
                Background="#2a2210"
                BorderBrush="#3d3418"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,10"
                Margin="24,12,24,0"
                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13"
                           Foreground="{DynamicResource WarningBrush}">
                    <Run Text="&#x26A0;"/>
                    <Run Text=" "/>
                    <Run Text="{Binding UpdateMessage, Mode=OneWay}" Foreground="{DynamicResource TextPrimary}"/>
                </TextBlock>

                <Button Grid.Column="1"
                        Content="查看更新"
                        Style="{StaticResource ButtonDefault}"
                        FontSize="12"
                        Padding="14,5"
                        Margin="12,0,0,0"
                        Command="{Binding OpenReleaseCommand}"/>

                <Button Grid.Column="2"
                        Content="&#x2715;"
                        FontSize="12"
                        Padding="8,4"
                        Margin="6,0,0,0"
                        Background="Transparent"
                        Foreground="{DynamicResource TextTertiary}"
                        BorderThickness="0"
                        Command="{Binding DismissUpdateCommand}"
                        Cursor="Hand"
                        ToolTip="忽略此版本更新">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ========== Row 2: Installation Options — Card Layout ========== -->
        <Grid Grid.Row="2" Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Global CFG -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BgSurface}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <!-- Card header -->
                    <CheckBox IsChecked="{Binding InstallCfgChecked}"
                              FontWeight="SemiBold" FontSize="13">
                        <CheckBox.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="全局配置" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text=" (CFG)" Foreground="{DynamicResource TextSecondary}" Margin="2,0,0,0"/>
                            </StackPanel>
                        </CheckBox.Content>
                    </CheckBox>

                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,10"/>

                    <!-- Path -->
                    <TextBlock Text="目标路径" FontSize="11"
                               Foreground="{DynamicResource TextTertiary}" Margin="0,6,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding Cs2CfgPath, Mode=OneWay, TargetNullValue='请点击刷新路径检测或手动选择'}"
                                 IsReadOnly="True" TextWrapping="NoWrap" Height="32"/>
                        <Button Grid.Column="1" Content="..."
                                Style="{StaticResource ButtonSmall}"
                                Command="{Binding SelectCfgFolderCommand}"
                                Width="36" Height="32" Margin="4,0,0,0"/>
                    </Grid>

                    <!-- Backup -->
                    <TextBlock Text="备份位置" FontSize="11"
                               Foreground="{DynamicResource TextTertiary}" Margin="0,8,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 IsReadOnly="True" TextWrapping="NoWrap" Height="32"
                                 Text="{Binding CfgBackupPath, Mode=OneWay, TargetNullValue='安装前将自动备份'}"/>
                        <Button Grid.Column="1" Content="打开"
                                Style="{StaticResource ButtonSmall}"
                                Command="{Binding OpenCfgBackupCommand}"
                                Height="32" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Card 2: User Video Preset -->
            <Border Grid.Column="2"
                    Background="{DynamicResource BgSurface}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <!-- Card header -->
                    <CheckBox IsChecked="{Binding InstallVideoChecked}"
                              FontWeight="SemiBold" FontSize="13">
                        <CheckBox.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="用户视频预设" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                        </CheckBox.Content>
                    </CheckBox>

                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,10"/>

                    <!-- Steam user dropdown -->
                    <TextBlock Text="Steam 用户" FontSize="11"
                               Foreground="{DynamicResource TextTertiary}" Margin="0,6,0,4"/>
                    <ComboBox ItemsSource="{Binding SteamUsers}"
                              SelectedIndex="{Binding SelectedSteamUserIndex}"
                              Height="32"/>

                    <!-- Path -->
                    <TextBlock Text="目标路径" FontSize="11"
                               Foreground="{DynamicResource TextTertiary}" Margin="0,8,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding VideoCfgPath, Mode=OneWay, TargetNullValue='请选择 Steam 用户'}"
                                 IsReadOnly="True" TextWrapping="NoWrap" Height="32"/>
                        <Button Grid.Column="1" Content="..."
                                Style="{StaticResource ButtonSmall}"
                                Command="{Binding SelectVideoFolderCommand}"
                                Width="36" Height="32" Margin="4,0,0,0"/>
                    </Grid>

                    <!-- Backup -->
                    <TextBlock Text="备份位置" FontSize="11"
                               Foreground="{DynamicResource TextTertiary}" Margin="0,8,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 IsReadOnly="True" TextWrapping="NoWrap" Height="32"
                                 Text="{Binding VideoBackupPath, Mode=OneWay, TargetNullValue='安装前将自动备份'}"/>
                        <Button Grid.Column="1" Content="打开"
                                Style="{StaticResource ButtonSmall}"
                                Command="{Binding OpenVideoBackupCommand}"
                                Height="32" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Card 3: Map Annotations -->
            <Border Grid.Column="4"
                    Background="{DynamicResource BgSurface}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <!-- Card header -->
                    <CheckBox IsChecked="{Binding InstallAnnotationsChecked}"
                              FontWeight="SemiBold" FontSize="13">
                        <CheckBox.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="地图指南预设" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                        </CheckBox.Content>
                    </CheckBox>

                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,10"/>

                    <!-- Path -->
                    <TextBlock Text="目标路径" FontSize="11"
                               Foreground="{DynamicResource TextTertiary}" Margin="0,6,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding AnnotationsPath, Mode=OneWay, TargetNullValue='请点击刷新路径检测'}"
                                 IsReadOnly="True" TextWrapping="NoWrap" Height="32"/>
                        <Button Grid.Column="1" Content="..."
                                Style="{StaticResource ButtonSmall}"
                                Command="{Binding SelectAnnotationsFolderCommand}"
                                Width="36" Height="32" Margin="4,0,0,0"/>
                    </Grid>

                    <!-- Backup -->
                    <TextBlock Text="备份位置" FontSize="11"
                               Foreground="{DynamicResource TextTertiary}" Margin="0,8,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 IsReadOnly="True" TextWrapping="NoWrap" Height="32"
                                 Text="{Binding AnnotationsBackupPath, Mode=OneWay, TargetNullValue='安装前将自动备份'}"/>
                        <Button Grid.Column="1" Content="打开"
                                Style="{StaticResource ButtonSmall}"
                                Command="{Binding OpenAnnotationsBackupCommand}"
                                Height="32" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Steam ID Guide Expander (full-width below cards) -->
        <Expander Margin="24,12,24,0" ExpandDirection="Down">
            <Expander.Header>
                <TextBlock Foreground="{DynamicResource LinkBrush}" FontWeight="SemiBold" FontSize="12">
                    &#x1F4D6; 如何查找我的 Steam 用户 (好友代码)？
                </TextBlock>
            </Expander.Header>
            <StackPanel Margin="10,8,10,10">
                <!-- Image display area -->
                <Border BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Background="{DynamicResource BgInput}"
                        Padding="5">
                    <Image x:Name="SteamGuideImage"
                           Source="/Resources/navi.png"
                           Stretch="Uniform"
                           MaxWidth="600"
                           MaxHeight="450"
                           HorizontalAlignment="Left"
                           MouseLeftButtonUp="SteamGuideImage_MouseUp"
                           Cursor="Hand"/>
                </Border>

                <!-- Tip text -->
                <TextBlock Margin="0,10,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource TextTertiary}"
                           TextWrapping="Wrap">
                    <Run Text="按照图中步骤操作，找到你的Steam好友ID后，"/>
                    <LineBreak/>
                    <Run Text="在上方的下拉框中选择对应的数字ID即可。如果userdata文件夹中只有一个账号，"/>
                    <LineBreak/>
                    <Run Text="系统通常会自动选中它。"/>
                </TextBlock>
            </StackPanel>
        </Expander>

        <!-- ========== Row 3: Drop Zone ========== -->
        <Grid Margin="24,16,24,0">
            <Border x:Name="DropZoneBorder"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="2"
                    Background="{DynamicResource BgInput}"
                    CornerRadius="8"
                    Padding="20"
                    Height="80"
                    AllowDrop="True"
                    Drop="DropZone_Drop"
                    DragOver="DropZone_DragOver"
                    DragLeave="DropZone_DragLeave"
                    MouseLeftButtonUp="DropZoneBorder_Click"
                    Cursor="Hand">
                <!-- Dashed border workaround: use a nested border -->
                <Border BorderBrush="{DynamicResource TextTertiary}"
                        BorderThickness="0"
                        CornerRadius="6">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="点击选择或拖放 ZIP/CFG 文件到此处"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding SelectedFileDisplay, Mode=OneWay}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

        <!-- ========== Row 4: Log Output ========== -->
        <Border Margin="24,16,24,0"
                Background="#0d0f15"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="2">
            <RichTextBox x:Name="LogTextBox"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="Transparent"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderThickness="0"
                         Padding="10,8"
                         MinHeight="150" MaxHeight="300" Height="180"/>
        </Border>

        <!-- ========== Row 5: Action Buttons ========== -->
        <StackPanel Margin="0,16,24,20"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">
            <Button Content="刷新路径"
                    Style="{StaticResource ButtonDefault}"
                    Command="{Binding RefreshCommand}"
                    Padding="20,8" Height="36" MinWidth="100" FontSize="13"/>
            <Button Content="进行备份"
                    Style="{StaticResource ButtonDefault}"
                    Command="{Binding BackupCommand}"
                    Margin="10,0,0,0" Padding="20,8" Height="36" MinWidth="100" FontSize="13"/>
            <Button Content="{Binding InstallButtonText, Mode=OneWay}"
                    Style="{StaticResource ButtonPrimary}"
                    Command="{Binding InstallCommand}"
                    Margin="10,0,0,0" Padding="24,8" Height="38" MinWidth="120" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
