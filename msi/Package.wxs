<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="SrP-CFG 安装器"
           Manufacturer="RoL1n"
           Version="$(Version)"
           ProductCode="$(ProductCode)"
           UpgradeCode="B5D3A1F2-7E4C-4D8F-9A2B-3C5E6F8D1A24"
           Scope="perMachine"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="已安装更新版本，无需降级。" />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="app.ico" SourceFile="..\app\desktop\resources\icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="app.ico" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="SrP-CFG_Installer" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="SrP-CFG" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="SrP-CFG 安装器" Level="1">
      <ComponentGroupRef Id="ElectronAppFiles" />
      <ComponentRef Id="StartMenuComponent" />
      <ComponentRef Id="DesktopComponent" />
    </Feature>

    <!-- Start menu shortcut — targets the Electron app exe -->
    <Component Directory="ApplicationProgramsFolder" Id="StartMenuComponent">
      <Shortcut Id="StartMenuShortcut"
                Name="SrP-CFG 安装器"
                Target="[INSTALLFOLDER]SrP-CFG Installer.exe"
                Icon="app.ico"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveStartMenuFolder" On="uninstall" />
      <RegistryKey Root="HKCU" Key="Software\SrP\SrP-CFG_Installer">
        <RegistryValue Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
      </RegistryKey>
    </Component>

    <!-- Desktop shortcut -->
    <Component Directory="DesktopFolder" Id="DesktopComponent">
      <Shortcut Id="DesktopShortcut"
                Name="SrP-CFG 安装器"
                Target="[INSTALLFOLDER]SrP-CFG Installer.exe"
                Icon="app.ico"
                WorkingDirectory="INSTALLFOLDER" />
      <RegistryKey Root="HKCU" Key="Software\SrP\SrP-CFG_Installer">
        <RegistryValue Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
      </RegistryKey>
    </Component>

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

  </Package>
</Wix>
