---
import { ArrowDownRight, BookOpen, Download } from "lucide-astro";
import ButtonLink from "./ButtonLink.astro";
import TerminalDemo from "./TerminalDemo.astro";
import { LATEST_VERSION } from "../data/version";
---

<section class="relative overflow-hidden border-b border-border pt-16">
  <div class="tech-grid pointer-events-none absolute inset-0 opacity-70" aria-hidden="true"></div>
  <div class="relative mx-auto grid min-h-[calc(100svh-4rem)] max-w-[1280px] grid-cols-1 items-center gap-12 px-5 py-20 sm:px-7 sm:py-24 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16 lg:py-20">
    <div class="hero-reveal max-w-[760px]">
      <div class="mb-6 flex flex-wrap items-center gap-3 font-mono text-xs uppercase tracking-[0.16em] text-text-muted">
        <span class="inline-flex items-center gap-2 rounded-full border border-teal/25 bg-teal/5 px-3 py-1.5 text-teal">
          <span class="h-1.5 w-1.5 rounded-full bg-teal" aria-hidden="true"></span>
          VCFG AWARE
        </span>
        <span>SrP-CFG v{LATEST_VERSION}</span>
      </div>

      <h1 class="font-display text-[clamp(3rem,7vw,6.5rem)] font-bold leading-[0.94] tracking-[-0.035em] text-text">
        功能留给<br />Runtime，
        <span class="text-accent">偏好留给你。</span>
      </h1>

      <p class="mt-7 max-w-[650px] text-base leading-8 text-text-secondary sm:text-lg">
        SrP-CFG v3 是一套面向 CS2 的模块化配置运行时。一个 Runtime Core 注册 alias、Feature 与 Mode；
        一个 <code class="font-mono text-[0.9em] text-accent-light">user/custom.cfg</code> 决定 Preset 起点和你的最终覆盖。
      </p>

      <div class="mt-9 flex flex-wrap gap-3">
        <ButtonLink href="/download" size="lg">
          <Download class="h-5 w-5" />
          获取 v3
        </ButtonLink>
        <ButtonLink href="/docs/srpcfg-1" variant="ghost" size="lg">
          <BookOpen class="h-5 w-5" />
          先理解架构
        </ButtonLink>
      </div>

      <a href="#architecture" class="mt-10 inline-flex min-h-11 items-center gap-2 font-mono text-xs uppercase tracking-[0.14em] text-text-faint no-underline transition-colors hover:text-accent">
        查看执行边界
        <ArrowDownRight class="h-4 w-4" />
      </a>
    </div>

    <div class="hero-reveal hero-reveal-delayed w-full min-w-0">
      <TerminalDemo />
    </div>
  </div>

  <div class="relative border-t border-border bg-bg-card/55">
    <dl class="mx-auto grid max-w-[1280px] grid-cols-2 gap-px bg-border sm:grid-cols-4">
      <div class="bg-bg-card/90 px-5 py-5 sm:px-6 sm:py-6">
        <dt class="font-mono text-[11px] uppercase tracking-[0.14em] text-text-faint">Release model</dt>
        <dd class="mt-1 font-display text-xl font-bold text-text">1 Runtime Core</dd>
      </div>
      <div class="bg-bg-card/90 px-5 py-5 sm:px-6 sm:py-6">
        <dt class="font-mono text-[11px] uppercase tracking-[0.14em] text-text-faint">Source tree</dt>
        <dd class="mt-1 font-display text-xl font-bold text-text">84 CFG</dd>
      </div>
      <div class="bg-bg-card/90 px-5 py-5 sm:px-6 sm:py-6">
        <dt class="font-mono text-[11px] uppercase tracking-[0.14em] text-text-faint">Preset cases</dt>
        <dd class="mt-1 font-display text-xl font-bold text-text">4 + Valve</dd>
      </div>
      <div class="bg-bg-card/90 px-5 py-5 sm:px-6 sm:py-6">
        <dt class="font-mono text-[11px] uppercase tracking-[0.14em] text-text-faint">User surface</dt>
        <dd class="mt-1 font-display text-xl font-bold text-text">1 custom.cfg</dd>
      </div>
    </dl>
  </div>
</section>
