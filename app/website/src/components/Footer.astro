---
import { REPO_URL } from "../data/navigation";
import { BookOpen, Download, Github } from "lucide-astro";

const footerLinks = [
  { href: "/docs", label: "项目文档", icon: BookOpen },
  { href: "/download", label: "前往下载", icon: Download },
  { href: REPO_URL, label: "GitHub", external: true, icon: Github },
];
---

<footer class="border-t border-border py-9 sm:py-12">
  <div class="mx-auto flex max-w-[1280px] flex-col items-start justify-between gap-6 px-5 sm:px-7 md:flex-row md:items-center">
    <div class="flex items-center gap-3">
      <img src="/favicon.ico" alt="" width="28" height="28" class="h-7 w-7 rounded-md" />
      <div>
        <span class="block font-display text-sm font-bold tracking-[0.08em] text-text-secondary">SrP-CFG</span>
        <span class="block font-mono text-[10px] uppercase tracking-[0.14em] text-text-faint">CS2 configuration runtime</span>
      </div>
    </div>
    <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
      {footerLinks.map((link) => {
        const Icon = link.icon;
        return (
          <a
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noopener" : undefined}
            data-astro-prefetch={link.external ? undefined : "hover"}
            class="inline-flex min-h-11 items-center gap-2 rounded-[var(--radius-sm)] px-3 font-display text-sm font-semibold text-text-muted no-underline transition-colors duration-200 hover:bg-bg-hover hover:text-accent"
          >
            <Icon class="w-4 h-4" />
            {link.label}
          </a>
        );
      })}
    </div>
  </div>
</footer>
