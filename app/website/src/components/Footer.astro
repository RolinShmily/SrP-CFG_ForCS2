---
import { REPO_URL } from "../data/navigation";
import { BookOpen, Download, Github } from "lucide-astro";

const footerLinks = [
  { href: "/docs", label: "项目文档", icon: BookOpen },
  { href: "/download", label: "前往下载", icon: Download },
  { href: REPO_URL, label: "GitHub", external: true, icon: Github },
];
---

<footer class="py-8 sm:py-12 border-t border-border">
  <div class="max-w-[1200px] mx-auto px-5 sm:px-7 flex flex-col md:flex-row items-center justify-between gap-4 sm:gap-5">
    <div class="flex items-center gap-2.5 font-display text-base font-semibold text-text-faint tracking-wider">
      <img src="/favicon.ico" alt="SrP-CFG" class="w-6 h-6" />
      <span>SrP-CFG Installer</span>
    </div>
    <div class="flex gap-6 items-center">
      {footerLinks.map((link) => {
        const Icon = link.icon;
        return (
          <a
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noopener" : undefined}
            class="inline-flex items-center gap-1.5 font-display text-sm font-medium text-text-muted hover:text-accent transition-colors duration-200 no-underline"
          >
            <Icon class="w-4 h-4" />
            {link.label}
          </a>
        );
      })}
    </div>
  </div>
</footer>
