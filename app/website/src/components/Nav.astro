---
import { navLinks, REPO_URL } from "../data/navigation";
import { Github, Menu, X } from "lucide-astro";

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath === href || currentPath.startsWith(`${href}/`);
---

<nav class="fixed inset-x-0 top-0 z-[100] border-b border-border bg-bg/95" aria-label="主导航">
  <div class="mx-auto flex h-16 w-full max-w-[1280px] items-center justify-between px-5 sm:px-7">
    <a href="/" data-astro-prefetch="hover" class="group flex min-h-11 items-center gap-3 no-underline" aria-label="SrP-CFG 首页">
      <img src="/favicon.ico" alt="" width="32" height="32" class="h-8 w-8 rounded-[7px]" />
      <span class="leading-none">
        <span class="block font-display text-lg font-bold tracking-[0.08em] text-text group-hover:text-accent">SrP-CFG</span>
        <span class="mt-1 block font-mono text-[10px] uppercase tracking-[0.16em] text-text-faint">v3 Runtime</span>
      </span>
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          data-astro-prefetch="hover"
          aria-current={isActive(link.href) ? "page" : undefined}
          class:list={[
            "inline-flex min-h-11 items-center rounded-[var(--radius-sm)] px-4 font-display text-sm font-semibold no-underline transition-colors duration-200",
            isActive(link.href)
              ? "bg-accent-bg text-accent"
              : "text-text-muted hover:bg-bg-hover hover:text-text",
          ]}
        >
          {link.label}
        </a>
      ))}
      <span class="mx-2 h-5 w-px bg-border" aria-hidden="true"></span>
      <a
        href={REPO_URL}
        target="_blank"
        rel="noopener"
        class="inline-flex min-h-11 items-center gap-2 rounded-[var(--radius-sm)] px-3 font-display text-sm font-semibold text-text-muted no-underline transition-colors duration-200 hover:bg-bg-hover hover:text-text"
      >
        <Github class="h-4 w-4" />
        GitHub
      </a>
    </div>

    <button
      id="mobile-menu-btn"
      type="button"
      class="flex h-11 w-11 items-center justify-center rounded-[var(--radius-sm)] border border-border bg-bg-card text-text-secondary transition-colors hover:border-border-highlight hover:text-text md:hidden"
      aria-label="打开主导航"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <Menu data-icon-menu class="h-5 w-5" />
      <X data-icon-close class="hidden h-5 w-5" />
    </button>
  </div>
</nav>

<div
  id="mobile-menu"
  class="fixed inset-x-0 top-16 z-[90] hidden border-b border-border bg-bg-card px-5 py-4 shadow-2xl md:hidden"
  aria-hidden="true"
>
  <div class="mx-auto flex max-w-[720px] flex-col gap-1">
    {navLinks.map((link) => (
      <a
        href={link.href}
        data-astro-prefetch="hover"
        aria-current={isActive(link.href) ? "page" : undefined}
        class:list={[
          "flex min-h-12 items-center rounded-[var(--radius-sm)] px-4 font-display text-base font-semibold no-underline transition-colors duration-200",
          isActive(link.href)
            ? "bg-accent-bg text-accent"
            : "text-text-muted hover:bg-bg-hover hover:text-text",
        ]}
      >
        {link.label}
      </a>
    ))}
    <a
      href={REPO_URL}
      target="_blank"
      rel="noopener"
      class="mt-1 flex min-h-12 items-center gap-2 rounded-[var(--radius-sm)] border-t border-border px-4 pt-3 font-display text-base font-semibold text-text-muted no-underline hover:text-text"
    >
      <Github class="h-5 w-5" />
      GitHub
    </a>
  </div>
</div>

<style>
  #mobile-menu-btn.menu-open [data-icon-menu] { display: none; }
  #mobile-menu-btn.menu-open [data-icon-close] { display: block; }
  :global(body.mobile-menu-open) { overflow: hidden; }
</style>

<script>
  const button = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");

  if (button && menu && button.dataset.ready !== "true") {
    button.dataset.ready = "true";
    let open = false;

    const setOpen = (next: boolean) => {
      open = next;
      menu.classList.toggle("hidden", !next);
      button.classList.toggle("menu-open", next);
      button.setAttribute("aria-expanded", String(next));
      button.setAttribute("aria-label", next ? "关闭主导航" : "打开主导航");
      menu.setAttribute("aria-hidden", String(!next));
      document.body.classList.toggle("mobile-menu-open", next);
    };

    button.addEventListener("click", () => setOpen(!open));
    menu.querySelectorAll("a").forEach((link) => link.addEventListener("click", () => setOpen(false)));
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && open) {
        setOpen(false);
        button.focus();
      }
    });
    window.matchMedia("(min-width: 768px)").addEventListener("change", (event) => {
      if (event.matches) setOpen(false);
    });
  }
</script>
