---
interface Props {
  href?: string;
  class?: string;
}

const { href, class: className = "" } = Astro.props;
const base =
  "rounded-[var(--radius)] border border-border bg-bg-card transition-[background-color,border-color,box-shadow,transform] duration-200";
const hoverable =
  "hover:-translate-y-0.5 hover:border-border-highlight hover:bg-bg-hover hover:shadow-[0_10px_32px_rgba(0,0,0,0.28)]";
const isLink = !!href;
---

{isLink ? (
  <a href={href} target="_blank" rel="noopener" class:list={[base, hoverable, "group block no-underline", className]}>
    <slot />
  </a>
) : (
  <div class:list={[base, className]}>
    <slot />
  </div>
)}
