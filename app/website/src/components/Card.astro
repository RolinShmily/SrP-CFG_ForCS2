---
interface Props {
  href?: string;
  class?: string;
}

const { href, class: className = "" } = Astro.props;
const Tag = href ? "a" : "div";
const base =
  "bg-bg-card border border-border rounded-[10px] transition-all duration-300";
const hoverable =
  "hover:border-border-highlight hover:bg-bg-hover hover:-translate-y-0.5 hover:shadow-[0_4px_24px_rgba(0,0,0,0.4)]";
const isLink = !!href;
---

{isLink ? (
  <a href={href} target="_blank" rel="noopener" class:list={[base, hoverable, "group block no-underline", className]}>
    <slot />
  </a>
) : (
  <div class:list={[base, className]}>
    <slot />
  </div>
)}
