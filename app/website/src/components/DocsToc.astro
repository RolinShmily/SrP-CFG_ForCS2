---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  roomy?: boolean;
}

const { headings, roomy = false } = Astro.props;
---

<nav aria-label="本页目录">
  <div class="mb-3 flex items-center justify-between">
    <span class="font-mono text-[10px] font-medium uppercase tracking-[0.15em] text-text-faint">On this page</span>
    <span class="font-mono text-[10px] text-text-faint">{String(headings.length).padStart(2, "0")}</span>
  </div>
  <ul class="border-l border-border">
    {headings.map((item) => (
      <li>
        <a
          href={`#${item.slug}`}
          data-toc-link
          data-toc-target={item.slug}
          class:list={[
            "-ml-px block border-l border-transparent pr-2 text-sm leading-5 text-text-muted no-underline transition-colors duration-200 hover:border-border-highlight hover:text-text",
            roomy ? "min-h-11 py-2.5" : "py-1.5",
            item.depth === 3 ? "pl-5" : "pl-3",
          ]}
        >
          {item.text}
        </a>
      </li>
    ))}
  </ul>
</nav>
