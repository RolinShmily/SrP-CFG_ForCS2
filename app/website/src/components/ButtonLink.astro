---
interface Props {
  href: string;
  variant?: "accent" | "ghost";
  size?: "md" | "lg";
}

const { href, variant = "accent", size = "md" } = Astro.props;

const variants = {
  accent:
    "border border-accent bg-accent text-bg hover:border-accent-light hover:bg-accent-light hover:shadow-[0_10px_32px_rgba(242,138,26,0.2)]",
  ghost:
    "border border-border-highlight bg-bg-card/70 text-text-secondary hover:border-text-muted hover:bg-bg-hover hover:text-text",
};

const sizes = {
  md: "min-h-11 px-6 py-2.5 text-sm",
  lg: "min-h-12 px-7 py-3 text-base sm:px-8",
};
---

<a
  href={href}
  data-astro-prefetch="hover"
  class:list={[
    "inline-flex items-center justify-center gap-2.5 rounded-[var(--radius-sm)] font-display font-semibold no-underline transition-[background-color,border-color,color,box-shadow] duration-200",
    variants[variant],
    sizes[size],
  ]}
>
  <slot />
</a>
