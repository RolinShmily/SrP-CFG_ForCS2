      },
      {
        "text": "普通模块入口只加载 settings；带 _keys 的入口加载 with-keymap。",
        "evidence": ["config/srp-cfg/runtime/commands.cfg:24", "config/srp-cfg/runtime/commands.cfg:25"]
      }
    ],
    "tags": ["settings", "keymap", "with-keymap", "_keys", "物理按键"],
    "curation": { "status": "reviewed", "source": "manual" }
