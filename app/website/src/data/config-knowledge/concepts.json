    "id": "concept:runtime-registration-boundary",
    "type": "concept",
    "title": "Runtime 只注册能力",
    "summary": "autoexec 先加载 Runtime 注册层；Runtime 负责注册公共 alias 与模块能力，不主动安装普通物理键位。",
    "claims": [
      {
        "text": "Runtime 初始化发生在用户覆盖层之前。",
        "evidence": ["config/autoexec.cfg:8", "config/autoexec.cfg:9"]
      },
      {
        "text": "Runtime 注册层不应主动应用个人偏好或普通物理键位。",
        "evidence": ["config/srp-cfg/runtime/init.cfg:3"]
      }
    ],
    "tags": ["runtime", "启动", "注册", "按键边界"],
    "curation": { "status": "reviewed", "source": "manual" }
  },
  {
    "id": "concept:settings-vs-keymap",
    "type": "concept",
    "title": "settings、keymap 与 with-keymap 的职责边界",
    "summary": "settings 只应用模块状态，keymap 才修改物理按键，with-keymap 按顺序组合二者。",
    "claims": [
      {
        "text": "with-keymap 先加载 settings，再加载 keymap。",
