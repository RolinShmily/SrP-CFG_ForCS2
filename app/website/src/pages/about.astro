---
import MainLayout from "../layouts/MainLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { Github, ExternalLink, Boxes, Shield, User, PenLine, Zap, Monitor, Atom, Paintbrush, Server, Code } from "lucide-astro";
import { REPO_URL, RELEASES_URL } from "../data/navigation";
import BilibiliIcon from "../components/icons/BilibiliIcon.astro";

const techStack = [
  { name: "Astro", desc: "静态站点生成框架", icon: Zap },
  { name: "Electron", desc: "桌面应用框架", icon: Monitor },
  { name: "React", desc: "共享 UI 组件库", icon: Atom },
  { name: "TailwindCSS", desc: "原子化 CSS 框架", icon: Paintbrush },
  { name: "Node.js", desc: "运行时环境", icon: Server },
  { name: "TypeScript", desc: "类型安全的开发语言", icon: Code },
];

const links = [
  { label: "GitHub 仓库", url: REPO_URL, icon: Github },
  { label: "GitHub Release", url: RELEASES_URL, icon: Github },
  { label: "SrP-CFG 视频系列", url: "https://space.bilibili.com/422744280/lists/6770542", icon: BilibiliIcon },
  { label: "关于 CFG 你要了解的二三事", url: "https://blog.srprolin.top/posts/srp-cfg/", icon: ExternalLink },
];

const contributors = [
  {
    name: "RoL1n",
    role: "开发维护",
    github: "RolinShmily",
    blog: "https://blog.srprolin.top",
    bilibili: "https://space.bilibili.com/422744280",
  },
];
---

<MainLayout title="关于 — SrP-CFG" description="SrP-CFG 项目介绍与开源信息">
  <section class="pt-[120px] pb-20">
    <div class="max-w-[1200px] mx-auto px-7">

      <div class="flex justify-center mb-10">
        <img src="/favicon.ico" alt="SrP-CFG Logo" class="w-28 h-28 rounded-2xl border border-border shadow-[0_0_40px_rgba(232,121,12,0.15)]" />
      </div>

      <SectionHeader label="About" title="关于 SrP-CFG" description="适用于 CS2（Counter-Strike 2）各场景的 CFG 预设文件，由 RoL1n 开发维护" />

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-16 max-w-[1000px] mx-auto">
        <div>
          <h2 class="font-display text-2xl font-semibold mb-6">项目简介</h2>
          <div class="space-y-4 text-text-secondary font-light leading-[1.8] mb-10">
            <p>
              SrP-CFG 是一套为 CS2 玩家打造的全套预设 CFG 配置文件。项目提供多种实用功能，包括准星视角设置、跑图练习、demo 录制、饰品预览等，旨在提升游戏体验。
            </p>
            <p>
              所有的 CFG 在运行后都会在控制台输出导航信息，通过 <code class="font-mono text-sm bg-bg-raised px-1.5 py-0.5 rounded text-accent-light">autoexec.cfg</code> 自启动加载，
              并通过 <code class="font-mono text-sm bg-bg-raised px-1.5 py-0.5 rounded text-accent-light">exec custom</code> 链式加载用户定制配置。
            </p>
          </div>

          <h2 class="font-display text-2xl font-semibold mb-6">快速链接</h2>
          <div class="space-y-3">
            {links.map((link) => {
              const Icon = link.icon;
              return (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener"
                  class="group flex items-center gap-3 p-4 bg-bg-card border border-border rounded-[10px] no-underline transition-all duration-300 hover:border-border-highlight hover:bg-bg-hover"
                >
                  <div class="w-8 h-8 rounded-[6px] bg-accent-bg border border-[rgba(232,121,12,0.12)] flex items-center justify-center flex-shrink-0 text-accent">
                    <Icon class="w-4 h-4" />
                  </div>
                  <span class="font-display text-sm font-medium text-text-secondary group-hover:text-accent transition-colors">
                    {link.label}
                  </span>
                </a>
              );
            })}
          </div>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold mb-6 flex items-center gap-3">
            <Boxes class="w-6 h-6 text-teal" />
            技术栈
          </h2>
          <div class="grid grid-cols-2 gap-3 mb-12">
            {techStack.map((tech) => {
              const Icon = tech.icon;
              return (
                <div class="p-4 bg-bg-card border border-border rounded-[10px]">
                  <div class="flex items-center gap-2 mb-1">
                    <Icon class="w-4 h-4 text-text-muted" />
                    <div class="font-display text-base font-semibold text-text">{tech.name}</div>
                  </div>
                  <div class="text-xs text-text-muted font-light">{tech.desc}</div>
                </div>
              );
            })}
          </div>

          <h2 class="font-display text-2xl font-semibold mb-6 flex items-center gap-3">
            <User class="w-6 h-6 text-accent" />
            贡献者
          </h2>
          <div class="space-y-3">
            {contributors.map((c) => (
              <div class="flex items-center gap-4 p-4 bg-bg-card border border-border rounded-[10px]">
                <img
                  src="/avatar.jpg"
                  alt={c.name}
                  class="w-12 h-12 rounded-full border border-[rgba(232,121,12,0.12)] object-cover"
                />
                <div>
                  <div class="font-display text-base font-semibold">{c.name}</div>
                  <div class="text-xs text-text-muted">{c.role}</div>
                </div>
                <div class="ml-auto flex items-center gap-2">
                  <a href={c.blog} target="_blank" rel="noopener" class="text-text-muted hover:text-accent transition-colors" title="Blog">
                    <PenLine class="w-[18px] h-[18px]" />
                  </a>
                  <a href={c.bilibili} target="_blank" rel="noopener" class="text-text-muted hover:text-accent transition-colors" title="Bilibili">
                    <BilibiliIcon class="w-[18px] h-[18px]" />
                  </a>
                  <a href={`https://github.com/${c.github}`} target="_blank" rel="noopener" class="text-text-muted hover:text-accent transition-colors" title="GitHub">
                    <Github class="w-[18px] h-[18px]" />
                  </a>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-8 p-5 bg-bg-card border border-border rounded-[10px] flex items-center gap-4">
            <Shield class="w-5 h-5 text-text-muted" stroke-width="1.8" />
            <div>
              <div class="font-display text-sm font-semibold">开源许可</div>
              <div class="text-xs text-text-muted">本仓库代码以自定义许可证发布，详见仓库根目录 LICENSE 文件</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
