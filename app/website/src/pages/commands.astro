  function initChat() {
    const fab = document.getElementById("ai-fab");
    const panel = document.getElementById("ai-panel");
    const closeBtn = document.getElementById("ai-close");
    const overlay = document.getElementById("ai-overlay");
    const sendBtn = document.getElementById("chat-send");
    const input = document.getElementById("chat-input") as HTMLTextAreaElement | null;
    
    const dbSrp = document.getElementById("db-srpcfg");
    const dbCmd = document.getElementById("db-commands");

    const selectDb = (dbType: ChatDatabase) => {
      if (dbType === currentDb || isStreaming) return;
      const srpSelected = dbType === "srpcfg";
      input?.setAttribute(
        "placeholder",
        srpSelected
          ? "询问配置位置、按键、alias 或生效范围..."
          : "查询 CS2 官方控制台指令...",
      );
      currentDb = dbType;
      dbSrp?.classList.toggle("border-accent", srpSelected);
      dbSrp?.classList.toggle("text-accent", srpSelected);
      dbSrp?.classList.toggle("border-transparent", !srpSelected);
      dbSrp?.classList.toggle("text-text-muted", !srpSelected);
      dbSrp?.setAttribute("aria-checked", String(srpSelected));

      dbCmd?.classList.toggle("border-accent", !srpSelected);
      dbCmd?.classList.toggle("text-accent", !srpSelected);
      dbCmd?.classList.toggle("border-transparent", srpSelected);
      dbCmd?.classList.toggle("text-text-muted", srpSelected);
      dbCmd?.setAttribute("aria-checked", String(!srpSelected));

      const sourceLabel = document.getElementById("ai-source-label");
      if (sourceLabel) {
        sourceLabel.textContent = srpSelected ? "检索 SrP-CFG 配置源码" : "检索 CS2 官方指令数据";
      }
      renderWelcomeMessage(dbType);
    };

    dbSrp?.addEventListener("click", () => selectDb("srpcfg"));
    dbCmd?.addEventListener("click", () => selectDb("commands"));

    // 小屏打开面板
    fab?.addEventListener("click", () => {
      panel?.classList.remove("translate-y-full", "opacity-0", "pointer-events-none");
