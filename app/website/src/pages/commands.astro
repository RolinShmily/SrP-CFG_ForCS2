// Turnstile Site Key 是公开标识，由构建环境变量注入；Secret Key 仅存在于 Worker。
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "";

interface TurnstileApi {
  render(container: string | HTMLElement, options: {
    sitekey: string;
    action: "chat";
    execution: "execute";
    appearance: "interaction-only";
    theme: "dark";
    language: "zh-CN";
    size: "flexible";
    responseField: false;
    retry: "never";
    callback: (token: string) => void;
    "error-callback": (errorCode: string) => void;
    "expired-callback": () => void;
    "timeout-callback": () => void;
  }): string;
  execute(widgetId: string): void;
  reset(widgetId: string): void;
}

let turnstileWidgetId: string | undefined;
let pendingTurnstileResolve: ((token: string) => void) | undefined;
let pendingTurnstileReject: ((error: Error) => void) | undefined;
let turnstileTimeoutId: number | undefined;

function rejectTurnstile(error: Error): void {
  if (turnstileTimeoutId !== undefined) window.clearTimeout(turnstileTimeoutId);
  const reject = pendingTurnstileReject;
  pendingTurnstileResolve = undefined;
  pendingTurnstileReject = undefined;
  turnstileTimeoutId = undefined;
  reject?.(error);
}

function describeTurnstileError(errorCode: string): string {
  if (errorCode === "110200") {
    return `当前域名 ${window.location.hostname} 未加入 Turnstile 允许列表（错误码 110200）。`;
  }
  if (["110100", "110110", "400020", "400070"].includes(errorCode)) {
    return `Turnstile Site Key 配置无效或已停用（错误码 ${errorCode}）。`;
  }
  if (errorCode === "200500") {
    return "Turnstile 验证组件加载失败，请检查广告拦截器或网络设置（错误码 200500）。";
  }
  if (errorCode.startsWith("300") || errorCode.startsWith("600")) {
    return `Turnstile 未能通过安全检查，请关闭代理后重试（错误码 ${errorCode}）。`;
  }
  return `Turnstile 验证失败，请重试（错误码 ${errorCode || "unknown"}）。`;
}

async function getTurnstileToken(): Promise<string> {
  if (!TURNSTILE_SITE_KEY) {
    throw new Error("Turnstile Site Key 未配置，AI 助手暂时不可用。");
  }

  const container = document.getElementById("turnstile-container");
  if (!container) throw new Error("Turnstile 容器不存在，请刷新页面重试。");

  // Turnstile is loaded by Cloudflare's external script and is not part of DOM typings.
  const api = (window as unknown as { turnstile?: TurnstileApi }).turnstile;
  if (!api) throw new Error("Turnstile 尚未加载完成，请稍后重试。");

  if (!turnstileWidgetId) {
    turnstileWidgetId = api.render(container, {
      sitekey: TURNSTILE_SITE_KEY,
      action: "chat",
      execution: "execute",
      appearance: "interaction-only",
      theme: "dark",
      language: "zh-CN",
      size: "flexible",
      responseField: false,
      retry: "never",
      callback: (token) => {
        if (turnstileTimeoutId !== undefined) window.clearTimeout(turnstileTimeoutId);
        const resolve = pendingTurnstileResolve;
        pendingTurnstileResolve = undefined;
        pendingTurnstileReject = undefined;
        turnstileTimeoutId = undefined;
        resolve?.(token);
      },
      "error-callback": (errorCode) => {
        rejectTurnstile(new Error(describeTurnstileError(errorCode)));
      },
      "expired-callback": () => {
        rejectTurnstile(new Error("Turnstile 验证已过期，请重试。"));
      },
      "timeout-callback": () => {
        rejectTurnstile(new Error("Turnstile 交互验证超时，请重试。"));
      },
    });
  } else {
    api.reset(turnstileWidgetId);
  }

  const widgetId = turnstileWidgetId;
  return new Promise((resolve, reject) => {
    pendingTurnstileResolve = resolve;
    pendingTurnstileReject = reject;
    turnstileTimeoutId = window.setTimeout(() => {
      rejectTurnstile(new Error("Turnstile 验证超时，请刷新页面后重试。"));
    }, 120_000);
    api.execute(widgetId);
  });
}

async function sendMessage() {
    const input = document.getElementById("chat-input") as HTMLTextAreaElement | null;
    if (!input || isStreaming) return;

    const message = input.value.trim();
    if (!message) return;

    // 清空输入框
    input.value = "";
    input.style.height = "auto";

    // 渲染用户消息
    appendMessage("user", message);

    // 渲染 AI 消息占位（流式填充）
    const aiBubble = appendMessage("assistant", "");
    const bubbleContent = aiBubble.querySelector("[data-bubble-content]") as HTMLElement;
    if (bubbleContent) bubbleContent.innerHTML = '<span class="inline-flex items-center gap-1 text-text-muted text-xs"><span class="w-1.5 h-1.5 bg-accent rounded-full animate-bounce" style="animation-delay:0ms"></span><span class="w-1.5 h-1.5 bg-accent rounded-full animate-bounce" style="animation-delay:150ms"></span><span class="w-1.5 h-1.5 bg-accent rounded-full animate-bounce" style="animation-delay:300ms"></span></span>';

    isStreaming = true;
    updateSendButton();

    try {
      const turnstileToken = await getTurnstileToken();
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          message,
          db: currentDb,
          history: chatHistory.slice(-6).map((item) => ({
            role: item.role,
            content: item.content.slice(0, 4_000),
          })),
          turnstileToken,
        }),
      });

      if (!res.ok) {
        let errText = `HTTP ${res.status}`;
        try {
          const errJson = await res.json();
          errText += ` - ${errJson.error || JSON.stringify(errJson)}`;
        } catch {
          // ignore parsing error
        }
        throw new Error(errText);
      }
      if (!res.body) throw new Error("No response body");

      // 清除加载动画
      if (bubbleContent) bubbleContent.innerHTML = "";

      // 读取 SSE 流
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = "";
      let fullText = "";

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });

        // 解析 SSE data: 行
        const lines = buffer.split("\n");
        buffer = lines.pop() || "";

        for (const line of lines) {
          const trimmed = line.trim();
          if (!trimmed || !trimmed.startsWith("data:")) continue;

          const jsonStr = trimmed.slice(5).trim();
          if (jsonStr === "[DONE]") continue;

          try {
            const parsed = JSON.parse(jsonStr);
            const chunk = parsed.response || "";
            fullText += chunk;
            if (bubbleContent) {
              bubbleContent.innerHTML = renderMarkdown(fullText);
              scrollToBottom();
            }
          } catch {
            // 忽略无法解析的行
          }
        }
      }

      // 保存到历史
      chatHistory.push({ role: "user", content: message });
      chatHistory.push({ role: "assistant", content: fullText });

    } catch (error: unknown) {
      const errorMessage = error instanceof Error ? error.message : String(error);
      if (bubbleContent) {
        bubbleContent.innerHTML = `<p class="text-red-400 text-sm">⚠️ 请求失败：${escapeHtml(errorMessage)}</p><p class="text-text-faint text-xs mt-1">请稍后重试，或直接使用左侧检索功能。</p>`;
      }
    } finally {
      isStreaming = false;
      updateSendButton();
    }
  }

  function appendMessage(role: "user" | "assistant", content: string) {
    const messagesEl = document.getElementById("chat-messages");
    if (!messagesEl) return {} as HTMLElement;

    const isUser = role === "user";
    const wrapper = document.createElement("div");
    wrapper.className = `flex gap-2.5 ${isUser ? "flex-row-reverse" : ""}`;

    const avatar = document.createElement("div");
    avatar.className = `w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5 ${isUser ? "bg-bg-raised border border-border" : "bg-accent-bg border border-accent/20"}`;
    avatar.innerHTML = isUser
      ? '<svg class="w-3.5 h-3.5 text-text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>'
      : '<svg class="w-3.5 h-3.5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M12 8v4M12 16h.01"/></svg>';

    const bubble = document.createElement("div");
    bubble.className = `flex-1 max-w-[85%]`;
    const inner = document.createElement("div");
    inner.setAttribute("data-bubble-content", "");
    inner.className = `rounded-[10px] px-3.5 py-2.5 text-sm leading-6 ${isUser ? "bg-accent text-bg rounded-tr-[3px]" : "bg-bg-hover text-text rounded-tl-[3px]"}`;
    inner.innerHTML = isUser ? escapeHtml(content) : renderMarkdown(content);

    bubble.appendChild(inner);
    wrapper.appendChild(avatar);
    wrapper.appendChild(bubble);
    messagesEl.appendChild(wrapper);
    scrollToBottom();

    return wrapper;
  }

  function renderMarkdown(text: string): string {
    if (!text) return "";
    let html = escapeHtml(text);

    // 反引号 `command_name` → 可点击复制
    html = html.replace(/`([^`\n]+)`/g, (_, command) => {
      return `<code class="inline-code" onclick="copyCommand(this, this.textContent || '')" title="点击复制" style="cursor:pointer">${command}</code>`;
    });

    // **bold**
    html = html.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');

    // 换行
    html = html.replace(/\n/g, '<br>');

    // 列表项 (行首 - 或 •)
    html = html.replace(/(?:^|<br>)((?:[-•]\s[^\n<]+(?:<br>|$))+)/g, (_, listBlock) => {
      const items = listBlock.split(/<br>|$/).filter((s: string) => s.trim()).map((s: string) => {
        return `<li>${s.replace(/^[-•]\s/, '').trim()}</li>`;
      }).join("");
      return `<ul class="list-disc list-inside space-y-0.5 my-1">${items}</ul>`;
    });

    return html;
  }

  function escapeHtml(text: string): string {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  function scrollToBottom() {
    const messagesEl = document.getElementById("chat-messages");
    if (messagesEl) messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function updateSendButton() {
    const sendBtn = document.getElementById("chat-send") as HTMLButtonElement | null;
    if (sendBtn) sendBtn.disabled = isStreaming;
  }

  // ============ 启动 ============
  initCommands();
  initChat();
</script>

