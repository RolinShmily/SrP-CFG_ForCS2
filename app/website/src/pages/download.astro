---
import MainLayout from "../layouts/MainLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Card from "../components/Card.astro";
import { Download, FileText, Info, Package } from "lucide-astro";
import { installers, packages } from "../data/downloads";
import { RELEASES_URL } from "../data/navigation";
---

<MainLayout title="下载 — SrP-CFG" description="下载 SrP-CFG 安装器和配置预设包">
  <section class="pt-[120px] pb-16">
    <div class="max-w-[1200px] mx-auto px-7">
      <SectionHeader label="Download" title="下载中心" description="获取安装器或直接下载配置预设包，所有文件均可通过拖拽安装" />

      <div class="mb-20">
        <h2 class="font-display text-2xl font-semibold mb-8 flex items-center gap-3">
          <Download class="w-6 h-6 text-accent" />
          安装器
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {installers.map((item) => (
            <Card href={item.url} class="p-8">
              <div class="flex items-start justify-between mb-4">
                <div>
                  <h3 class="font-display text-xl font-semibold mb-1 group-hover:text-accent transition-colors">{item.name}</h3>
                  <span class="font-mono text-sm text-text-faint">{item.file}</span>
                </div>
                <span class="inline-block px-3 py-1 text-xs font-mono font-semibold tracking-wider rounded-[4px] bg-accent-bg text-accent border border-[rgba(232,121,12,0.12)]">
                  {item.badge}
                </span>
              </div>
              <p class="text-sm text-text-secondary font-light leading-[1.75] mb-6">{item.desc}</p>
              <div class="flex items-center gap-2 text-accent font-display text-sm font-semibold">
                <Download class="w-4 h-4" />点击下载
              </div>
            </Card>
          ))}
        </div>
      </div>

      <div>
        <h2 class="font-display text-2xl font-semibold mb-8 flex items-center gap-3">
          <Package class="w-6 h-6 text-teal" />
          配置预设包
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {packages.map((pkg) => (
            <Card href={pkg.url} class:list={["p-6", pkg.featured && "border-accent/20"]}>
              <div class="flex items-center gap-3 mb-3">
                <div class:list={[
                  "w-10 h-10 rounded-[6px] flex items-center justify-center",
                  pkg.featured ? "bg-accent-bg border border-[rgba(232,121,12,0.12)]" : "bg-bg-raised border border-border",
                ]}>
                  <Download class:list={["w-[18px] h-[18px]", pkg.featured ? "text-accent" : "text-text-muted"]} stroke-width="1.8" />
                </div>
                {pkg.featured && (
                  <span class="text-[10px] font-mono font-bold tracking-wider px-2 py-0.5 rounded bg-accent text-bg">DEFAULT</span>
                )}
              </div>
              <h3 class="font-display text-lg font-semibold mb-1.5 group-hover:text-accent transition-colors">{pkg.name}</h3>
              <p class="text-xs text-text-secondary font-light leading-[1.75] mb-4">{pkg.desc}</p>
              <span class="font-mono text-xs text-text-faint">{pkg.file}</span>
            </Card>
          ))}
        </div>
      </div>

      <div class="mt-12 p-6 bg-bg-card border border-border rounded-[10px] flex gap-4">
        <div class="w-10 h-10 rounded-[6px] bg-accent-bg border border-[rgba(232,121,12,0.12)] flex items-center justify-center flex-shrink-0">
          <Info class="w-[18px] h-[18px] text-accent" stroke-width="1.8" />
        </div>
        <div>
          <h4 class="font-display text-base font-semibold mb-1">使用说明</h4>
          <p class="text-sm text-text-secondary font-light leading-[1.75]">
            下载安装器后双击运行，将配置预设包（ZIP）直接拖入窗口即可自动完成安装。所有文件也可在
            <a href={RELEASES_URL} target="_blank" rel="noopener" class="text-accent hover:underline">GitHub Releases</a>
            找到。
          </p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
