---
import BaseLayout from "./BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  title: string;
  description: string;
  docs: CollectionEntry<"docs">[];
  currentSlug: string;
  headings: { depth: number; slug: string; text: string }[];
}

const { title, description, docs, currentSlug, headings } = Astro.props;
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

const guideOrder = ["srpcfg-1", "srpcfg-3"];
const guideDocs = guideOrder
  .map((id) => docs.find((d) => d.id === id))
  .filter(Boolean) as CollectionEntry<"docs">[];
const cfgDocs = docs.filter((d) => !guideOrder.includes(d.id) && d.id !== "srpcfg-2");
---

<BaseLayout title={title} description={description}>
  <Nav />
  <div class="max-w-[1440px] mx-auto pt-20">
    <div class="flex">
      <!-- Left Sidebar — Doc Navigation -->
      <aside class="w-56 shrink-0 hidden lg:block">
        <nav class="sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto pr-4 pb-8" id="doc-sidebar">
          <a
            href="/docs/srpcfg-1"
            class="block font-display text-sm font-semibold text-text-muted hover:text-text transition-colors no-underline mb-3 tracking-wider"
          >
            文档中心
          </a>

          <!-- Guide section -->
          <ul class="flex flex-col gap-0.5 mb-4">
            {guideDocs.map((doc) => {
              const isActive = doc.id === currentSlug;
              return (
                <li>
                  <a
                    href={`/docs/${doc.id}`}
                    class:list={[
                      "block py-1.5 px-3 rounded-[6px] text-sm transition-colors no-underline font-display",
                      isActive
                        ? "bg-accent-bg text-accent font-medium"
                        : "text-text-muted hover:text-text hover:bg-bg-hover",
                    ]}
                  >
                    {doc.data.title}
                  </a>
                </li>
              );
            })}
          </ul>

          <!-- Separator -->
          <div class="h-px bg-border my-3"></div>

          <!-- CFG files section -->
          <span class="block font-display text-[11px] font-semibold text-text-faint tracking-widest mb-2 px-3">
            CFG 文件
          </span>
          <ul class="flex flex-col gap-0.5">
            {cfgDocs.map((doc) => {
              const isActive = doc.id === currentSlug;
              return (
                <li>
                  <a
                    href={`/docs/${doc.id}`}
                    class:list={[
                      "block py-1.5 px-3 rounded-[6px] text-sm transition-colors no-underline font-display",
                      isActive
                        ? "bg-accent-bg text-accent font-medium"
                        : "text-text-muted hover:text-text hover:bg-bg-hover",
                    ]}
                  >
                    {doc.data.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>
      </aside>

      <!-- Center — Doc Content -->
      <article
        transition:name="doc-main"
        transition:animate="fade"
        class="flex-1 min-w-0 px-4 md:px-8 lg:px-12 pb-16 prose-doc"
      >
        <slot />
      </article>

      <!-- Right Sidebar — Table of Contents -->
      <aside class="w-48 shrink-0 hidden xl:block">
        {
          toc.length > 0 && (
            <nav class="sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto pb-8" id="toc-nav">
              <span class="block font-display text-xs font-semibold text-text-faint tracking-widest mb-3">
                本页目录
              </span>
              <ul class="flex flex-col gap-0">
                {toc.map((item) => (
                  <li>
                    <a
                      href={`#${item.slug}`}
                      data-toc-link
                      data-toc-target={item.slug}
                      class:list={[
                        "block py-1 text-[13px] leading-snug transition-colors no-underline",
                        item.depth === 3 && "pl-3",
                        "text-text-muted hover:text-text",
                      ]}
                    >
                      {item.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )
        }
      </aside>
    </div>
  </div>
  <Footer />
</BaseLayout>

<style>
  .prose-doc {
    color: var(--color-text-secondary);
    line-height: 1.8;
    font-weight: 300;
  }

  .prose-doc :global(h1) {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
    letter-spacing: 0.02em;
  }

  .prose-doc :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .prose-doc :global(h3) {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose-doc :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose-doc :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .prose-doc :global(a:hover) {
    opacity: 0.8;
  }

  .prose-doc :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .prose-doc :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .prose-doc :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }

  .prose-doc :global(thead th) {
    font-family: var(--font-display);
    font-weight: 600;
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-text);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  .prose-doc :global(tbody td) {
    padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .prose-doc :global(tbody tr:hover) {
    background: var(--color-bg-hover);
  }

  .prose-doc :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-raised);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--color-accent-light);
  }

  .prose-doc :global(pre) {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose-doc :global(pre code) {
    background: none;
    padding: 0;
    color: var(--color-text-secondary);
  }

  .prose-doc :global(ul),
  .prose-doc :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose-doc :global(li) {
    margin-bottom: 0.375rem;
  }

  .prose-doc :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .prose-doc :global(img) {
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    max-width: 100%;
  }

  .prose-doc :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  [data-toc-link].toc-active {
    color: var(--color-accent);
  }
</style>

<script>
  // Scroll-spy for TOC
  const tocLinks = document.querySelectorAll("[data-toc-link]");
  if (tocLinks.length > 0) {
    const targets = new Map<string, HTMLElement>();
    tocLinks.forEach((link) => {
      const slug = link.getAttribute("data-toc-target");
      if (slug) {
        const el = document.getElementById(slug);
        if (el) targets.set(slug, el);
      }
    });

    const observer = new IntersectionObserver(
      (entries) => {
        let activeSlug = "";
        for (const entry of entries) {
          if (entry.isIntersecting) {
            activeSlug = entry.target.id;
            break;
          }
        }
        if (activeSlug) {
          tocLinks.forEach((link) => {
            const slug = link.getAttribute("data-toc-target");
            link.classList.toggle("toc-active", slug === activeSlug);
          });
        }
      },
      { rootMargin: "-80px 0px -70% 0px" },
    );

    targets.forEach((el) => observer.observe(el));
  }

  // Re-run when Astro View Transitions swaps content
  document.addEventListener("astro:page-load", () => {
    const links = document.querySelectorAll("[data-toc-link]");
    if (links.length > 0) {
      const t = new Map<string, HTMLElement>();
      links.forEach((link) => {
        const slug = link.getAttribute("data-toc-target");
        if (slug) {
          const el = document.getElementById(slug);
          if (el) t.set(slug, el);
        }
      });
      const obs = new IntersectionObserver(
        (entries) => {
          let s = "";
          for (const e of entries) {
            if (e.isIntersecting) { s = e.target.id; break; }
          }
          if (s) {
            links.forEach((l) => {
              const slug = l.getAttribute("data-toc-target");
              l.classList.toggle("toc-active", slug === s);
            });
          }
        },
        { rootMargin: "-80px 0px -70% 0px" },
      );
      t.forEach((el) => obs.observe(el));
    }
  });
</script>
