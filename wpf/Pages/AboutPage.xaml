<Page x:Class="SrPInstaller.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:SrPInstaller.ViewModels"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="关于">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0">
            <Image Source="/Resources/app.ico" Width="64" Height="64"
                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock HorizontalAlignment="Center" FontSize="28" FontWeight="Bold">
                <Run Text="SrP-CFG"/>
                <Run Text="安装器" Foreground="{DynamicResource TextFillColorAccentBrush}"/>
            </TextBlock>
            <TextBlock Text="{Binding AppVersion, Mode=OneWay, StringFormat='版本 {0}'}"
                       HorizontalAlignment="Center" FontSize="14"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>

            <TextBlock Text="CS2 配置预设管理器 — 一键部署、自动备份、版本更新"
                       HorizontalAlignment="Center" FontSize="14"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,24,0,0"
                       TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400"/>

            <ui:Card Margin="0,32,0,0" Width="360" HorizontalAlignment="Center" Padding="0">
                <StackPanel>
                    <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                               Appearance="Transparent"
                               Command="{Binding OpenUrlCommand}"
                               CommandParameter="{x:Static vm:AboutViewModel.GitHubRepoUrl}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xF1AC;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="GitHub 仓库"/>
                        </StackPanel>
                    </ui:Button>
                    <Separator Margin="14,0"/>
                    <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                               Appearance="Transparent"
                               Command="{Binding OpenUrlCommand}"
                               CommandParameter="{x:Static vm:AboutViewModel.WebsiteUrl}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="官方网站"/>
                        </StackPanel>
                    </ui:Button>
                    <Separator Margin="14,0"/>
                    <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                               Appearance="Transparent"
                               Command="{Binding OpenUrlCommand}"
                               CommandParameter="{x:Static vm:AboutViewModel.DocUrl}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="在线文档"/>
                        </StackPanel>
                    </ui:Button>
                    <Separator Margin="14,0"/>
                    <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                               Appearance="Transparent"
                               Command="{Binding OpenUrlCommand}"
                               CommandParameter="{x:Static vm:AboutViewModel.GitHubReleasesUrl}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="最新下载"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ui:Card>

            <TextBlock HorizontalAlignment="Center" Margin="0,32,0,0"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="11" TextWrapping="Wrap"
                       TextAlignment="Center">
                <Run Text="由 RolinShmily 开发维护"/>
                <LineBreak/>
                <Run Text="源代码基于 MIT 协议开源"/>
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</Page>
