<ui:FluentWindow x:Class="SrPInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:pages="clr-namespace:SrPInstaller.Pages"
        xmlns:vm="clr-namespace:SrPInstaller.ViewModels"
        Title="SrP-CFG 安装器"
        Width="900" Height="600"
        MinWidth="700" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ui:FluentWindow.Resources>

    <DockPanel>
        <ui:TitleBar x:Name="AppTitleBar"
                     DockPanel.Dock="Top"
                     Title="SrP-CFG 安装器"
                     ForceShutdown="True">
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock Text="{Binding AppVersion, StringFormat='v{0}', Mode=OneWay}"
                               FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0"
                                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding UpdateMessage, Mode=OneWay}" FontSize="11"
                                   Foreground="#e87912" VerticalAlignment="Center"/>
                        <ui:Button Content="查看" FontSize="10" Padding="8,2" Margin="6,0,0,0"
                                   Appearance="Transparent" Command="{Binding OpenReleaseCommand}"/>
                        <ui:Button Content="&#x2715;" FontSize="10" Padding="4,2" Margin="3,0,0,0"
                                   Appearance="Transparent" Command="{Binding DismissUpdateCommand}"/>
                    </StackPanel>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <ui:NavigationView x:Name="RootNavigation"
                           PaneDisplayMode="Left"
                           OpenPaneLength="180"
                           IsPaneToggleVisible="True"
                           ScrollViewer.CanContentScroll="False">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="安装" TargetPageType="{x:Type pages:InstallPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Home24"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="下载" TargetPageType="{x:Type pages:DownloadPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="ArrowDownload24"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="关于" TargetPageType="{x:Type pages:AboutPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Info24"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="文档"
                    Command="{Binding OpenUrlCommand}"
                    CommandParameter="{x:Static vm:AboutViewModel.DocUrl}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Document24"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="官网"
                    Command="{Binding OpenUrlCommand}"
                    CommandParameter="{x:Static vm:AboutViewModel.WebsiteUrl}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Globe24"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="GitHub"
                    Command="{Binding OpenUrlCommand}"
                    CommandParameter="{x:Static vm:AboutViewModel.GitHubRepoUrl}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Link24"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>
    </DockPanel>
</ui:FluentWindow>
